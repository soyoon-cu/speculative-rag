# ── GCP ────────────────────────────────────────────────────────────────────────
GCP_PROJECT_ID=speculative-rag
GCP_REGION=us-central1
PROJECT_NAME=standard-rag

# ── GCS bucket (created by make infra-apply) ───────────────────────────────────
GCS_BUCKET=standard-rag-bucket

# ── HuggingFace token (for gated models like Mistral) ─────────────────────────
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Eval settings ──────────────────────────────────────────────────────────────
TOP_K=10
MAX_NEW_TOKENS=100
RESULTS_PATH=output/results.json
